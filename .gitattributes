# Git Attributes for Prisma AIRS Repository

# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Jupyter Notebooks
*.ipynb linguist-documentation

# Python
*.py text eol=lf
*.pyi text eol=lf
*.pyw text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# JSON
*.json text eol=lf

# Markdown
*.md text eol=lf
*.markdown text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# Postman Cloud sync - use ours strategy to prefer git version
.postman/resources.yaml merge=ours

# JavaScript/TypeScript
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# Configuration
.env* text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.config text eol=lf

# Documentation
*.txt text eol=lf
*.rtf text eol=lf
LICENSE text eol=lf
README* text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary

# Archives
*.7z binary
*.gz binary
*.tar binary
*.tgz binary
*.rar binary

# Exclude files from export
.gitattributes export-ignore
.gitignore export-ignore
.github/ export-ignore
