# Prisma AIRS Repository .gitignore

# ==============================================================================
# SECURITY - API Keys and Credentials
# ==============================================================================
.env
.env.local
.env.*.local
config.json
secrets.json
credentials.json
*_secrets.*
*_credentials.*
**/*api_key*
**/*token*
.secrets/

# ==============================================================================
# Python
# ==============================================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
