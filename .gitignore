# ==============================================================================
# Jupyter Notebooks - Additional Security
# ==============================================================================
# Jupyter notebook outputs (may contain sensitive data)
*.ipynb

# BUT include notebooks without outputs using git filters
# Add this to your workflow:
# jupyter nbconvert --clear-output --inplace *.ipynb

# ==============================================================================
# Postman
# ==============================================================================
# Postman environment files (contain sensitive variables)
*.postman_environment.json
postman_environment.json

# Postman globals (may contain API keys)
*.postman_globals.json
postman_globals.json

